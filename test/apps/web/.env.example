# Google Maps API — Street View & satellite imagery
# Get your key at: https://console.cloud.google.com/apis/credentials
# Required APIs: Maps Static API, Street View Static API
GOOGLE_MAPS_API_KEY=

# Google Gemini API (optional — users provide their own key via the UI)
# Only needed as a server-side fallback. Get one at: https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=

# US Census Bureau API — income / demographic data for the agent
# Get your free key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# HUD User API — Fair Market Rent data for the agent
# Register at: https://www.huduser.gov/hudapi/public/register
HUD_API_TOKEN=

# NYC Open Data (Socrata SODA API) — PLUTO parcel data (optional, works without)
# Get your free app token at: https://data.cityofnewyork.us/profile/edit/developer_settings
# NYC_OPENDATA_TOKEN=

# NYC PLUTO dataset resource ID (Socrata) — changes with each annual release
# Current default: 64uk-42ks (24v4). Override here if a newer version is published.
# PLUTO_RESOURCE_ID=64uk-42ks
